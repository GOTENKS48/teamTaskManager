{
  "name": "team-task-manager",
  "version": "1.0.0",
  "description": "A full-stack team task manager with role-based access control, project management, and task tracking",
  "main": "src/index.js",
  "scripts": {
    "start": "npx prisma migrate deploy && node src/index.js",
    "dev": "node --watch src/index.js",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio",
    "seed": "node prisma/seed.js"
  },
  "keywords": ["task-manager", "project-management", "rbac", "team"],
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
